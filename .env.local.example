# PIM local dev environment — copy to .env.local and fill in.
# .env.local is gitignored. Never commit real values.
#
# Tags:
#   [GENERATED] minted by `just dev-up` on first run; do NOT set by hand.
#   [STATIC]    set once by the developer or left at default.
#
# Three-layer config discipline (see docs/configuration.md, plan D10):
#   Layer A (non-secret config)        -> apps/<svc>/config.toml
#   Layer B (non-symmetric key files)  -> zitadel-key.json (prod only)
#   Layer C (symmetric secret strings) -> this file, mounted via `env_file`
# This file is Layer C.

# ---- Zitadel instance masterkey (D13) -------------------------------------
# Exactly 32 chars. Immutable after first boot. `just dev-up` generates it
# on first run and writes it here. Regenerated only via `just dev-reset`
# (which also wipes the Postgres volume).
ZITADEL_MASTERKEY=                 # [GENERATED]

# ---- Zitadel admin credential (D12) ---------------------------------------
# PAT dispensed by Zitadel on first boot via ZITADEL_FIRSTINSTANCE_ORG_MACHINE_*.
# pim-bootstrap reads this to authenticate against the Management API.
# Copied into place by `just dev-up` after reading it from the
# zitadel-bootstrap volume (/zitadel/bootstrap/pim-admin.pat).
ZITADEL_ADMIN_PAT=                 # [GENERATED]

# ---- user-service runtime credential (Layer C) ----------------------------
# Long-lived PAT belonging to the `pim-user-service` service account that
# pim-bootstrap provisions. Used at runtime to call Zitadel Management API
# on behalf of end users. Minted by `just dev-bootstrap`.
USER_SERVICE__ZITADEL_SERVICE_ACCOUNT_TOKEN=   # [GENERATED]
